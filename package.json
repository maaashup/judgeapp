{
  "name": "judge-app",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "setup": "pnpm -r install && pnpm db:generate",
    "dev": "pnpm --parallel dev",
    "dev:api": "pnpm --filter @judge/api dev",
    "dev:mobile": "pnpm --filter @judge/mobile dev",
    "build:mobile": "pnpm --filter @judge/mobile build",
    "db:generate": "pnpm --filter @judge/db prisma:generate",
    "db:migrate": "pnpm --filter @judge/db prisma:migrate",
    "db:reset": "pnpm --filter @judge/db prisma:reset",
    "db:studio": "pnpm --filter @judge/db prisma:studio",
    "format": "prettier --write . && pnpm --filter @judge/mobile format",
    "lint": "eslint . && pnpm --filter @judge/mobile lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/api/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/db/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/mobile/**/*.dart": [
      "dart format"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  }
}
