{
  "name": "Judge App Stack",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000, 5432, 8100],
  "remoteUser": "node",
  "postCreateCommand": "corepack enable && pnpm -v",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "Prisma.prisma",
        "firsttris.vscode-jest-runner"
      ]
    }
  }
}